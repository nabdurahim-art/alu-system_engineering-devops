#!/usr/bin/env bash
# Configures Nginx with a 301 permanent redirect on /redirect_me

apt-get update -y
apt-get install nginx -y

echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html
echo "Holberton School for the win!" > /var/www/html/index.html

# Inject the rewrite rule directly inside the default server configuration block
REDIRECT_RULE="\\\tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n\t}"
sed -i "s|server_name _;|$&\n$REDIRECT_RULE|" /etc/nginx/sites-available/default

service nginx restart
